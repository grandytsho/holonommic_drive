<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
       xmlns:ignition="https://ignitionrobotics.org">

    <xacro:property name="wheel_radius"    value="0.0323"/>
    <xacro:property name="wheel_thickness" value="0.0352"/>
    <xacro:property name="mesh_z_offset"   value="0.0024"/>

    <!--
        BUG FIX: "file://$(find bot)/meshes" is a roslaunch substitution — it
        does NOT work inside xacro and will cause a runtime FileNotFoundError.
        The correct xacro-compatible URI is "package://bot/meshes".
    -->
    <xacro:property name="mesh_pkg" value="file://$(find bot)/meshes"/>

    <!--
    WHY SPHERE COLLISION FOR MECANUM WHEELS
    ========================================
    A cylinder collider contacts the ground along its full bottom edge, which
    can produce multiple simultaneous contact points under DART. Each contact
    point gets its own independent friction computation, and if any of them
    jitter or slip slightly out of phase, you get friction torque oscillations
    that fight the MecanumDrive plugin's velocity commands — this shows up as
    the robot vibrating in place or drifting when commanding pure lateral motion.

    A sphere collider produces exactly ONE contact point with the ground at
    all times. This means:
      1. A single, stable friction computation per wheel per timestep.
      2. No contact-edge instability when the wheel spins.
      3. The ignition:expressed_in="chassis" fdir1 anisotropy is applied to
         that single point consistently — no averaging artefacts.

    The sphere radius = wheel_radius so the wheel hub sits at the correct
    height above the ground (same as a cylinder of the same radius would).
    The wheel_thickness no longer affects ground clearance — only the radius
    does — which is physically correct since it's the roller tips that touch
    the ground, not the wheel edge.

    DART fdir1 / expressed_in explanation
    ======================================
    Normally fdir1 is evaluated in the wheel LINK frame. As the wheel spins,
    fdir1 rotates with it and averages to isotropic over one revolution.
    Result: DART resists all lateral motion → no strafing.

    ignition:expressed_in="chassis" (gz-physics PR #224) locks fdir1 to the
    CHASSIS frame. The chassis does not spin with the wheel, so the 45-degree
    roller anisotropy is maintained at every contact point throughout the
    simulation. DART then correctly applies:
      mu  = 10.0  along fdir1        (roller GRIPS the ground here)
      mu2 =  0.5  perpendicular      (roller SLIDES with low resistance here)

    fdir1 per corner — standard mecanum X-pattern:
      front_left  / back_right  →  "1 -1 0"   ( \ rollers )
      front_right / back_left   →  "1  1 0"   ( / rollers )

    If your robot drifts diagonally instead of strafing straight, your physical
    wheels use the O-pattern instead. In that case swap: front_left gets
    "1 1 0" and front_right gets "1 -1 0" (and similarly for the rear).
    -->

    <xacro:macro name="mecanum_wheel" params="prefix x_reflect y_reflect mesh_file fdir">

        <!-- ── Joint ──────────────────────────────────────────────────────── -->
        <joint name="${prefix}_joint" type="continuous">
            <parent link="chassis"/>
            <child  link="${prefix}_wheel"/>
            <origin
                xyz="${x_reflect * (chassis_length/2 - wheel_radius)}
                     ${y_reflect * (chassis_width/2  + wheel_thickness/2)}
                     -0.05"
                rpy="${pi/2} 0 0"/>
            <axis xyz="0 0 -1"/>
        </joint>

        <!-- ── Link ───────────────────────────────────────────────────────── -->
        <link name="${prefix}_wheel">

            <!-- Visual: real mecanum mesh, right wheels mirrored in Y -->
            <visual>
                <origin xyz="0 0 ${-mesh_z_offset}" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${mesh_pkg}/${mesh_file}"
                          scale="1 ${y_reflect} 1"/>
                </geometry>
            </visual>

            <!--
                SPHERE COLLISION
                radius = wheel_radius so the contact height matches the mesh.
                A sphere gives one clean contact point — no multi-edge DART
                instability that cylinder bottom-edges produce.
            -->
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
            </collision>

            <!--
                Inertia: still modelled as a cylinder (the actual mass
                distribution is closer to a cylinder than a solid sphere).
                Inertia does not have to match the collision primitive.
            -->
            <xacro:inertial_cylinder mass="0.2"
                length="${wheel_thickness}" radius="${wheel_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>

        </link>

        <!-- ── Gazebo / DART surface properties ───────────────────────────── -->
        <gazebo reference="${prefix}_wheel">
            <collision>
                <surface>
                    <friction>
                        <ode>
                            <!--
                                mu  = 10.0  High grip along roller axis.
                                            Can be tuned down toward 1.0 if the
                                            robot overshoots under acceleration.
                                mu2 =  0.5  Low but non-zero slide resistance.
                                            Pure 0.0 can cause the wheel to
                                            slip completely when the robot is
                                            accelerating; 0.5 gives realistic
                                            roller drag without killing strafing.
                            -->
                            <mu>5.0</mu>
                            <mu2>0.0</mu2>

                            <!--
                                THE KEY LINE — locks friction direction to the
                                chassis frame so the anisotropy doesn't rotate
                                away as the wheel spins. See explanation above.
                            -->
                            <fdir1 ignition:expressed_in="base_link">${fdir}</fdir1>

                            <!--
                                slip1/slip2: small values damp contact chatter.
                                Keep low; setting to 0 can cause jitter.
                            -->
                            <slip1>0.01</slip1>
                            <slip2>0.01</slip2>
                        </ode>
                    </friction>

                    <contact>
                        <ode>
                            <!--
                                kp: contact stiffness. 1e6 is appropriate for
                                a ~3 kg robot on a rigid ground plane. If the
                                robot visibly sinks into the floor, increase kp.
                                kd: contact damping — prevents bouncing.
                                max_vel / min_depth: standard Gazebo contact
                                correction parameters. Leave as-is unless you
                                see penetration artefacts.
                            -->
                            <kp>1000000.0</kp>
                            <kd>100.0</kd>
                            <max_vel>1.0</max_vel>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
            <material>Gazebo/Black</material>
        </gazebo>

    </xacro:macro>
</robot>