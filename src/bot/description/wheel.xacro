<?xml version="1.0"?>
<!--
    xmlns:ignition declared here so xacro passes ignition:expressed_in
    through to the SDF parser without stripping it.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
       xmlns:ignition="https://ignitionrobotics.org">

    <xacro:property name="wheel_radius"    value="0.0323"/>
    <xacro:property name="wheel_thickness" value="0.0352"/>
    <xacro:property name="mesh_z_offset"   value="0.0024"/>
    <xacro:property name="mesh_pkg" value="file://$(find bot)/meshes"/>

    <!--
    WHY THIS WORKS
    ==============
    DART normally evaluates fdir1 in the wheel link frame. As the wheel spins,
    fdir1 rotates with it and averages to isotropic over one revolution this
    is exactly why strafing does not work with plain cylinder wheels under DART.

    The ignition:expressed_in="chassis" attribute (from gz-physics PR -#224)
    instructs DART to evaluate fdir1 in the CHASSIS frame instead. The chassis
    does not rotate with the wheel spin, so the friction anisotropy stays
    locked at the correct 45-degree roller angle throughout the simulation.

    DART then sees:
      mu  = 1.0 along fdir1      (roller grips the ground in this direction)
      mu2 = 0.0 perpendicular    (roller slides freely in this direction)

    This is the physical contact behavior of a real mecanum roller, achieved
    with a plain cylinder collision -no roller meshes, no extra joints,
    no physics engine swap required.

    fdir1 per corner (standard mecanum X-pattern, vectors in chassis XY plane):
      front_left  : "1 -1 0"   rollers slope front-right to back-left
      front_right : "1  1 0"   rollers slope front-left  to back-right
      back_left   : "1  1 0"
      back_right  : "1 -1 0"

    References:
      https://github.com/gazebosim/gz-sim/pull/683
      https://github.com/gazebosim/gz-physics/pull/224
    -->

    <xacro:macro name="mecanum_wheel" params="prefix x_reflect y_reflect mesh_file fdir">

        <joint name="${prefix}_joint" type="continuous">
            <parent link="chassis"/>
            <child  link="${prefix}_wheel"/>
            <origin
                xyz="${x_reflect * (chassis_length/2 - wheel_radius)}
                     ${y_reflect * (chassis_width/2  + wheel_thickness/2)}
                     -0.05"
                rpy="${pi/2} 0 0"/>
            <axis xyz="0 0 -1"/>
        </joint>

        <link name="${prefix}_wheel">

            <visual>
                <origin xyz="0 0 ${-mesh_z_offset}" rpy="0 0 0"/>
                <geometry>
                    <mesh filename="${mesh_pkg}/${mesh_file}"
                          scale="1 ${y_reflect} 1"/>
                </geometry>
            </visual>

            <!-- Cylinder collision: stable under DART, correct size from mesh -->
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
                </geometry>
            </collision>

            <xacro:inertial_cylinder mass="0.2"
                length="${wheel_thickness}" radius="${wheel_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>

        </link>

        <!-- ── Physics-accurate anisotropic friction surface ─────────────── -->
        <gazebo reference="${prefix}_wheel">
            <collision>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>0.0</mu2>
                            <!--
                                THE KEY LINE.
                                expressed_in="chassis" locks this direction to
                                the chassis frame, not the spinning wheel frame.
                                This is what makes DART produce real mecanum
                                contact physics without roller meshes.
                            -->
                            <fdir1 ignition:expressed_in="chassis">${fdir}</fdir1>
                            <slip1>0.01</slip1>
                            <slip2>0.01</slip2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1000000.0</kp>
                            <kd>100.0</kd>
                            <max_vel>1.0</max_vel>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
            <material>Gazebo/Black</material>
        </gazebo>
    </xacro:macro>
</robot>